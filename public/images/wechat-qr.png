<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 300 300" fill="none">
  <rect width="300" height="300" rx="16" fill="#F0F9FF"/>
  <rect x="40" y="40" width="220" height="220" rx="12" fill="white" stroke="#E2E8F0" stroke-width="2"/>
  <!-- QR code placeholder pattern -->
  <g fill="#0C4A6E" opacity="0.15">
    <rect x="70" y="70" width="20" height="20" rx="2"/>
    <rect x="100" y="70" width="20" height="20" rx="2"/>
    <rect x="130" y="70" width="20" height="20" rx="2"/>
    <rect x="70" y="100" width="20" height="20" rx="2"/>
    <rect x="130" y="100" width="20" height="20" rx="2"/>
    <rect x="70" y="130" width="20" height="20" rx="2"/>
    <rect x="100" y="130" width="20" height="20" rx="2"/>
    <rect x="130" y="130" width="20" height="20" rx="2"/>
    <rect x="170" y="70" width="20" height="20" rx="2"/>
    <rect x="200" y="70" width="20" height="20" rx="2"/>
    <rect x="170" y="100" width="20" height="20" rx="2"/>
    <rect x="200" y="130" width="20" height="20" rx="2"/>
    <rect x="70" y="170" width="20" height="20" rx="2"/>
    <rect x="130" y="170" width="20" height="20" rx="2"/>
    <rect x="170" y="170" width="20" height="20" rx="2"/>
    <rect x="200" y="170" width="20" height="20" rx="2"/>
    <rect x="100" y="200" width="20" height="20" rx="2"/>
    <rect x="130" y="200" width="20" height="20" rx="2"/>
    <rect x="170" y="200" width="20" height="20" rx="2"/>
  </g>
  <!-- Center logo -->
  <circle cx="150" cy="150" r="20" fill="#0369A1"/>
  <circle cx="150" cy="150" r="10" fill="white"/>
  <circle cx="150" cy="150" r="5" fill="#0EA5E9"/>
  <!-- Label -->
  <text x="150" y="285" text-anchor="middle" font-family="system-ui, sans-serif" font-size="14" fill="#94A3B8">
    扫码关注公众号
  </text>
</svg>
